/*.zip
/*.tgz
/*.tmp
/*.temp
/*.bak
/*.orig
/screenshot_test*.png
/main-screen*.png
/a11y-product-rg.txt
/audit/
/NUL
/%SystemDrive%/
/testResults.xml
