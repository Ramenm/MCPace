# Generated runtime state
/backups/
/data/
/dist/
/logs/
/mcpace.cmd
/mcpace.sh

# OS/editor local artifacts
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# Local secrets
/.env
/.env.*
!/.env.example

# Local IDE and agent state
# memory-bank/ is intentionally tracked because release-manifest.json requires it.
/.omx/
/.omc/
/.claude/
/.playwright-mcp/
/.serena/
/.vscode/
/.idea/
/TestResults/

# Temporary, test, and packaging output
/*.zip
/*.tgz
/*.tmp
/*.temp
/*.bak
/*.orig
/screenshot_test*.png
/%SystemDrive%/
/testResults.xml
/junit.xml
/coverage.xml
/coverage/
/.nyc_output/
/playwright-report/
/test-results/
/target/
/.tmp/
/.tmp-*/
/.tmp-archive-test/

/node_modules/
/packages/**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python/tool caches from local verification helpers
__pycache__/
*.py[cod]
/.pytest_cache/
/.ruff_cache/
/.mypy_cache/

# Local MCP settings fragments are machine-specific; keep README/examples tracked.
/mcp_settings.d/*.json
!/mcp_settings.d/*.example.json
