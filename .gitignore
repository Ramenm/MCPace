/target/
/.tmp/
/.tmp-*/
/.tmp-archive-test/

/node_modules/
/packages/**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python/tool caches from local verification helpers
__pycache__/
*.py[cod]
/.pytest_cache/
/.ruff_cache/
/.mypy_cache/

# Registry snapshots are generated per user/query and can be very large.
/catalog/registry-cache*.json

# Local MCP settings fragments are machine-specific; keep README/examples tracked.
/mcp_settings.d/*.json
!/mcp_settings.d/*.example.json
