# Optional auth overrides
MCPACE_BEARER_TOKEN=replace-with-a-random-local-token
MCPACE_ADMIN_PASSWORD_BCRYPT=replace-with-a-bcrypt-hash

# Optional serve/client URL overrides
# MCPACE_SERVE_HOST=127.0.0.1
# MCPACE_SERVE_PORT=39022
# MCPACE_SERVE_PATH=/mcp
# MCPACE_PUBLIC_MCP_URL=https://your-relay.example/mcp

# Optional upstream/client catalog extension points
# MCPACE_MCP_SETTINGS=/absolute/path/to/extra-mcp-settings.json
# MCPACE_CLIENT_CATALOG=/absolute/path/to/client-targets.json

# Optional integrations
# GITHUB_PERSONAL_ACCESS_TOKEN=
# FIRECRAWL_API_KEY=
# WIRESHARK_MCP_ALLOWED_DIRS=/workspace
