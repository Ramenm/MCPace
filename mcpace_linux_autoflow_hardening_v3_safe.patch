+#!/usr/bin/env node
+import fs from 'node:fs';
+import os from 'node:os';
+import path from 'node:path';
+import process from 'node:process';
+import { spawnSync } from 'node:child_process';
+import { fileURLToPath } from 'node:url';
+
+const repoRoot = path.resolve(path.dirname(fileURLToPath(import.meta.url)), '..');
+const DEFAULT_PROFILE = process.env.MCPACE_LINUX_CHECK_PROFILE || 'standard';
+const DEFAULT_PORT = 39022;
+const DEFAULT_TIMEOUT_MS = 8000;
+const DANGEROUS_RELEASE_SEGMENTS = new Set([
+  '.git',
+  'node_modules',
+  'target',
+  '.claude',
+  '.codex',
+  '.omc',
+  '%SystemDrive%',
+  '__MACOSX'
+]);
+const NPX_BASELINE_ENV_VARS = [
+  'NPM_CONFIG_REGISTRY',
+  'NPM_CONFIG_USERCONFIG',
+  'NPM_CONFIG_GLOBALCONFIG',
+  'NPM_CONFIG_CACHE',
+  'NODE_EXTRA_CA_CERTS',
+  'SSL_CERT_FILE',
+  'REQUESTS_CA_BUNDLE',
+  'HTTP_PROXY',
+  'HTTPS_PROXY',
+  'NO_PROXY',
+  'http_proxy',
+  'https_proxy',
+  'no_proxy',
+  'CI'
+];
+
+function parseArgs(argv) {
+  const parsed = {
+    profile: DEFAULT_PROFILE,
+    json: false,
+    noDocker: false,
+    strict: false,
+    dryRun: false,
+    createDirs: false,
+    smoke: false,
+    root: process.env.MCPACE_ROOT || repoRoot,
+    bin: process.env.MCPACE_BIN || process.env.MCPACE_BINARY_PATH || '',
+    port: Number.parseInt(process.env.MCPACE_SERVE_PORT || String(DEFAULT_PORT), 10),
+    timeoutMs: Number.parseInt(process.env.MCPACE_LINUX_CHECK_TIMEOUT_MS || String(DEFAULT_TIMEOUT_MS), 10),
+    servers: [],
+    write: null,
+    markdown: null
+  };
+
+  for (let index = 0; index < argv.length; index += 1) {
+    const token = argv[index];
+    switch (token) {
+      case '--profile':
+        parsed.profile = argv[++index] || parsed.profile;
+        break;
+      case '--json':
+        parsed.json = true;
+        break;
+      case '--no-docker':
+        parsed.noDocker = true;
+        break;
+      case '--strict':
+        parsed.strict = true;
+        break;
+      case '--dry-run':
+        parsed.dryRun = true;
+        break;
+      case '--create-dirs':
+        parsed.createDirs = true;
+        break;
+      case '--smoke':
+        parsed.smoke = true;
+        break;
+      case '--root':
+        parsed.root = argv[++index] || parsed.root;
+        break;
+      case '--bin':
+        parsed.bin = argv[++index] || parsed.bin;
+        break;
+      case '--port':
+        parsed.port = Number.parseInt(argv[++index] || String(DEFAULT_PORT), 10);
+        break;
+      case '--timeout-ms':
+        parsed.timeoutMs = Number.parseInt(argv[++index] || String(DEFAULT_TIMEOUT_MS), 10);
+        break;
+      case '--servers':
+        parsed.servers = (argv[++index] || '').split(',').map((value) => value.trim()).filter(Boolean);
+        break;
+      case '--write':
+        parsed.write = argv[++index] || null;
+        break;
+      case '--markdown':
+        parsed.markdown = argv[++index] || null;
+        break;
+      case '-h':
+      case '--help':
+        printHelp();
+        process.exit(0);
+      default:
+        throw new Error(`unsupported linux-auto-check argument: ${token}`);
+    }
+  }
+
+  if (!['standard', 'host', 'full', 'release'].includes(parsed.profile)) {
+    throw new Error(`unsupported --profile '${parsed.profile}', expected standard|host|full|release`);
