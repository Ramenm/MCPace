+  lines.push('');
+  lines.push(`Status: **${report.status}**`);
+  lines.push(`Profile: **${report.profile}**`);
+  lines.push(`Generated: ${report.generatedAt}`);
+  lines.push(`Root: \`${report.root}\``);
+  lines.push('');
+  lines.push('| Status | Check | Message |');
+  lines.push('|---|---|---|');
+  for (const check of report.checks) {
+    lines.push(`| ${check.status} | ${check.name} | ${escapeMarkdown(check.message)} |`);
+  }
+  lines.push('');
+  lines.push('## Next actions');
+  const failures = report.checks.filter((check) => check.status === 'fail');
+  const warnings = report.checks.filter((check) => check.status === 'warn');
+  if (failures.length === 0 && warnings.length === 0) {
+    lines.push('- No blockers found by this checker.');
+  } else {
+    for (const check of [...failures, ...warnings].slice(0, 20)) {
+      lines.push(`- ${check.status.toUpperCase()} ${check.name}: ${check.message}`);
+    }
+  }
+  lines.push('');
+  return `${lines.join('\n')}\n`;
+}
+
+function escapeMarkdown(value) {
+  return String(value).replaceAll('|', '\\|').replaceAll('\n', ' ');
+}
+
+function writeOutputFile(filePath, content) {
+  const absolute = path.resolve(repoRoot, filePath);
+  fs.mkdirSync(path.dirname(absolute), { recursive: true });
+  fs.writeFileSync(absolute, content);
+}
+
+function main() {
+  const options = parseArgs(process.argv.slice(2));
+  const checks = [];
+  const add = (name, status, message, details = {}) => checks.push({ name, status, message, details });
+
+  checkHostBasics(add, options);
+  checkProjectSource(add);
+  checkProjectQuality(add, options);
+  checkUserFlow(add, options);
+  checkReleaseManifestHygiene(add);
+  checkArchiveReleaseExclusions(add);
+  checkVendoredExecutableBits(add);
+  checkLinuxSystemdAutostartSource(add);
+  checkDockerInstallProof(add, options);
+
+  const report = {
+    schema: 'mcpace.linuxAutoCheck.v1',
+    status: summarizeStatus(checks, options),
+    profile: options.profile,
+    strict: options.strict,
+    dryRun: options.dryRun,
+    generatedAt: new Date().toISOString(),
+    root: options.root,
+    stateRoot: process.env.MCPACE_STATE_ROOT || defaultStateRoot(),
+    bin: resolveMcpaceBinary(options.bin),
+    checks
+  };
+
+  if (options.write) writeOutputFile(options.write, `${JSON.stringify(report, null, 2)}\n`);
+  if (options.markdown) writeOutputFile(options.markdown, markdownReport(report));
+
+  if (options.json) {
+    process.stdout.write(`${JSON.stringify(report, null, 2)}\n`);
+  } else {
+    process.stdout.write(`MCPace Linux auto-check: ${report.status}\n`);
+    for (const check of checks) process.stdout.write(`- ${check.status.toUpperCase()} ${check.name}: ${check.message}\n`);
+  }
+  process.exit(report.status === 'fail' ? 1 : 0);
+}
+
+try {
+  main();
+} catch (error) {
+  process.stderr.write(`${error instanceof Error ? error.message : String(error)}\n`);
+  process.exit(1);
+}
diff --git a/scripts/linux-auto-setup.sh b/scripts/linux-auto-setup.sh
new file mode 100755
index 0000000..7fd2994
--- /dev/null
+++ b/scripts/linux-auto-setup.sh
@@ -0,0 +1,326 @@
+#!/usr/bin/env bash
+set -Eeuo pipefail
+
+APP_NAME="MCPace"
+DEFAULT_PORT="39022"
+DEFAULT_PROFILE="manual"
+INSTALL_SERVICE="auto"
+INSTALL_CLIENTS="0"
+RUN_SMOKE="1"
+ROOT="${MCPACE_ROOT:-}"
+BIN="${MCPACE_BIN:-${MCPACE_BINARY_PATH:-}}"
+PORT="${MCPACE_SERVE_PORT:-$DEFAULT_PORT}"
+SERVERS="${MCPACE_SERVERS:-}"
+
+usage() {
+  cat <<'USAGE'
+Usage: scripts/linux-auto-setup.sh [options]
+
+User-level Linux bootstrap for MCPace. It creates a safe XDG config root when
+missing, initializes runtime state, starts the local endpoint, and installs a
+user-level systemd autostart entry when systemd --user is available.
+
+Options:
+  --root <path>          MCPace user/project root. Default: $MCPACE_ROOT or $XDG_CONFIG_HOME/mcpace
+  --bin <path>           mcpace binary. Default: $MCPACE_BIN, $MCPACE_BINARY_PATH, PATH, or target/release/mcpace
+  --port <n>             Local MCPace port. Default: 39022
+  --install-service      Force user-level autostart install
+  --no-service           Do not install autostart
+  --install-clients      Allow setup to write supported local client config entries
+  --skip-client-install  Keep client configs untouched. This is the default.
+  --no-smoke             Create/init only; do not start setup smoke
+  --servers a,b          After setup, test selected upstream MCP servers
+  -h, --help             Show this help
+
+Environment:
+  MCPACE_ROOT, MCPACE_STATE_ROOT, MCPACE_BIN, MCPACE_BINARY_PATH,
+  MCPACE_SERVE_PORT, MCPACE_SERVERS
+USAGE
+}
+
+log() { printf '== %s ==\n' "$*"; }
+warn() { printf 'WARN: %s\n' "$*" >&2; }
+fail() { printf 'ERROR: %s\n' "$*" >&2; exit 1; }
+
+while [[ $# -gt 0 ]]; do
+  case "$1" in
+    --root)
+      ROOT="${2:-}"; shift 2 ;;
+    --bin)
+      BIN="${2:-}"; shift 2 ;;
+    --port)
+      PORT="${2:-}"; shift 2 ;;
+    --install-service)
+      INSTALL_SERVICE="yes"; shift ;;
+    --no-service)
+      INSTALL_SERVICE="no"; shift ;;
+    --install-clients)
+      INSTALL_CLIENTS="1"; shift ;;
+    --skip-client-install)
+      INSTALL_CLIENTS="0"; shift ;;
+    --no-smoke)
+      RUN_SMOKE="0"; shift ;;
+    --servers)
+      SERVERS="${2:-}"; shift 2 ;;
+    -h|--help)
+      usage; exit 0 ;;
+    *)
+      fail "unsupported argument: $1" ;;
+  esac
+done
+
+if [[ "$(uname -s)" != "Linux" ]]; then
+  fail "this bootstrap is Linux-only; use the native setup flow for other OSes"
+fi
+
+case "$PORT" in
+  ''|*[!0-9]*) fail "--port must be numeric" ;;
+esac
+if (( PORT < 1 || PORT > 65535 )); then
+  fail "--port must be between 1 and 65535"
+fi
+
+if [[ -z "$ROOT" ]]; then
+  ROOT="${XDG_CONFIG_HOME:-$HOME/.config}/mcpace"
+fi
+
+resolve_path() {
+  local value="$1"
+  if command -v python3 >/dev/null 2>&1; then
+    python3 -c 'import os,sys; print(os.path.abspath(os.path.expanduser(sys.argv[1])))' "$value"
+    return
+  fi
+  case "$value" in
+    ~) value="$HOME" ;;
+    ~/*) value="$HOME/${value#~/}" ;;
+  esac
+  if command -v realpath >/dev/null 2>&1 && realpath "$value" >/dev/null 2>&1; then
+    realpath "$value"
+    return
+  fi
+  local dir base
+  dir="$(dirname "$value")"
+  base="$(basename "$value")"
+  if [[ "$dir" != /* ]]; then
+    dir="$PWD/$dir"
+  fi
+  if (cd "$dir" >/dev/null 2>&1); then
+    (cd "$dir" >/dev/null 2>&1 && printf '%s/%s\n' "$(pwd -P)" "$base")
+  else
+    printf '%s\n' "$value"
+  fi
+}
+
+ROOT="$(resolve_path "$ROOT")"
+
+if [[ -z "${MCPACE_STATE_ROOT:-}" ]]; then
+  export MCPACE_STATE_ROOT="${XDG_STATE_HOME:-$HOME/.local/state}/mcpace"
+fi
+
+resolve_bin() {
+  if [[ -n "$BIN" ]]; then
+    printf '%s\n' "$BIN"
+    return
+  fi
+  if command -v mcpace >/dev/null 2>&1; then
+    command -v mcpace
+    return
+  fi
+  if [[ -x ./target/release/mcpace ]]; then
+    printf '%s\n' "./target/release/mcpace"
+    return
+  fi
+  if [[ -x ./target/debug/mcpace ]]; then
+    printf '%s\n' "./target/debug/mcpace"
+    return
+  fi
+  return 1
+}
+
+BIN="$(resolve_bin)" || fail "mcpace binary not found; pass --bin /path/to/mcpace or install @mcpace/cli"
+[[ -x "$BIN" ]] || fail "mcpace binary is not executable: $BIN"
+
+mkdir -p "$ROOT" "$ROOT/mcp_settings.d" "$MCPACE_STATE_ROOT"
+chmod 700 "$ROOT" "$ROOT/mcp_settings.d" "$MCPACE_STATE_ROOT" 2>/dev/null || true
+
+CONFIG_PATH="$ROOT/mcpace.config.json"
+SETTINGS_PATH="$ROOT/mcp_settings.json"
+README_PATH="$ROOT/mcp_settings.d/README.md"
+
+if [[ ! -f "$CONFIG_PATH" ]]; then
+  log "Creating user-level mcpace.config.json at $CONFIG_PATH"
+  VERSION="$($BIN version 2>/dev/null | head -n 1 | tr -d '\r' || true)"
+  [[ -n "$VERSION" ]] || VERSION="0.0.0"
+  VERSION="${VERSION//\\/\\\\}"
+  VERSION="${VERSION//\"/\\\"}"
+  cat > "$CONFIG_PATH" <<CONFIG_EOF
+{
+  "name": "mcpace-user",
+  "version": "$VERSION",
+  "ports": {
+    "serve": $PORT
+  },
+  "serve": {
+    "host": "127.0.0.1",
+    "port": $PORT,
+    "mcpPath": "/mcp",
+    "publicUrl": "",
+    "description": "Local-only Streamable HTTP endpoint created by scripts/linux-auto-setup.sh."
+  },
+  "profiles": {
+    "runtime": {
+      "default": "$DEFAULT_PROFILE",
+      "profiles": {
+        "$DEFAULT_PROFILE": {
+          "description": "No upstream MCP servers are enabled by default. Add servers explicitly to mcp_settings.json or mcp_settings.d/*.json.",
+          "serverOverrides": {}
+        }
+      }
+    }
+  },
+  "projects": {
+    "discovery": {
+      "roots": []
+    }
+  },
+  "workspaces": {
+    "primary": {
+      "name": "primary",
+      "hostPath": ".",
+      "access": "rw"
+    },
+    "extras": []
+  },
+  "servers": {},
+  "client": {
+    "keyName": "MCPace"
+  },
+  "mcpSettings": {
+    "includePaths": [],
+    "includeDirs": ["mcp_settings.d"],
+    "description": "User-level MCP settings. Keep secrets in environment variables and reference them through env_vars."
+  },
+  "mcpPresets": {
+    "includePaths": [],
+    "description": "Optional user-level preset catalogs."
+  }
+}
+CONFIG_EOF
+  chmod 600 "$CONFIG_PATH" 2>/dev/null || true
+else
+  log "Keeping existing config: $CONFIG_PATH"
+fi
+
+if [[ ! -f "$SETTINGS_PATH" ]]; then
+  log "Creating empty mcp_settings.json"
+  cat > "$SETTINGS_PATH" <<'SETTINGS_EOF'
+{
+  "mcpServers": {}
+}
+SETTINGS_EOF
+  chmod 600 "$SETTINGS_PATH" 2>/dev/null || true
+fi
+
+if [[ ! -f "$README_PATH" ]]; then
+  cat > "$README_PATH" <<'README_EOF'
+Drop additional MCP settings JSON files here. Later files override earlier ones.
+Prefer env_vars over inline env values so secrets stay outside config files.
+README_EOF
+fi
+
+systemd_user_available() {
+  command -v systemctl >/dev/null 2>&1 && systemctl --user show-environment >/dev/null 2>&1
+}
+
+wait_health() {
+  local url="http://127.0.0.1:$PORT/healthz"
+  local ok="0"
+  for _ in $(seq 1 40); do
+    if command -v curl >/dev/null 2>&1 && curl -fsS "$url" >/dev/null 2>&1; then ok="1"; break; fi
+    if command -v node >/dev/null 2>&1 && node -e 'fetch(process.argv[1]).then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))' "$url" >/dev/null 2>&1; then ok="1"; break; fi
+    sleep 0.25
+  done
+  [[ "$ok" == "1" ]] || fail "health check failed: $url"
+}
+
+verify_user_service() {
+  local unit="mcpace.service"
+  if ! systemd_user_available; then
+    warn "systemd --user is unavailable; cannot prove autostart. This is expected in some WSL/container sessions."
+    return 0
+  fi
+  log "Verifying systemd user service"
+  systemctl --user daemon-reload || fail "systemctl --user daemon-reload failed"
+  if ! systemctl --user is-enabled --quiet "$unit"; then
+    warn "$unit was not enabled by mcpace; enabling explicitly for compatibility with older builds"
+    systemctl --user enable "$unit" || fail "systemctl --user enable $unit failed"
+  fi
+  systemctl --user restart "$unit" || fail "systemctl --user restart $unit failed"
+  wait_health
+}
+
+log "Preflight"
+if [[ -f scripts/linux-auto-check.mjs ]] && command -v node >/dev/null 2>&1; then
+  node scripts/linux-auto-check.mjs --profile host --no-docker --root "$ROOT" --bin "$BIN" --create-dirs || true
+else
+  warn "scripts/linux-auto-check.mjs or node not available; skipping extended preflight"
+fi
+
+log "Initialize runtime state"
+"$BIN" init --json --root "$ROOT" >/tmp/mcpace-linux-init.json
+cat /tmp/mcpace-linux-init.json
+printf '\n'
+
+SETUP_ARGS=(setup --json --root "$ROOT" --host 127.0.0.1 --port "$PORT")
+if [[ "$INSTALL_CLIENTS" != "1" ]]; then
+  SETUP_ARGS+=(--skip-client-install)
+fi
+
+if [[ "$INSTALL_SERVICE" == "yes" ]] || [[ "$INSTALL_SERVICE" == "auto" && systemd_user_available ]]; then
+  SETUP_ARGS+=(--install-service)
+  log "User-level autostart will be installed"
+elif [[ "$INSTALL_SERVICE" == "auto" ]]; then
+  warn "systemd --user is not available; setup will run without autostart"
+fi
+
+if [[ "$RUN_SMOKE" == "1" ]]; then
+  log "Run setup smoke"
+  "$BIN" "${SETUP_ARGS[@]}" >/tmp/mcpace-linux-setup.json
+  cat /tmp/mcpace-linux-setup.json
+  printf '\n'
+  wait_health
+else
+  log "Skipping setup smoke by request"
+fi
+
+if [[ "$INSTALL_SERVICE" == "yes" ]] || [[ "$INSTALL_SERVICE" == "auto" && systemd_user_available ]]; then
+  verify_user_service
+fi
+
+if [[ -n "$SERVERS" ]]; then
+  IFS=',' read -r -a SERVER_LIST <<< "$SERVERS"
+  for server in "${SERVER_LIST[@]}"; do
+    server="${server//[[:space:]]/}"
+    [[ -n "$server" ]] || continue
+    log "Testing upstream server: $server"
+    "$BIN" server test "$server" --refresh --timeout-ms 30000 --json --root "$ROOT" || true
+  done
+fi
+
+log "Final service status"
+"$BIN" service status --json --root "$ROOT" --host 127.0.0.1 --port "$PORT" || true
+
+cat <<DONE_EOF
+
+$APP_NAME Linux setup complete.
+Root:       $ROOT
+State root: $MCPACE_STATE_ROOT
+Binary:     $BIN
+Endpoint:   http://127.0.0.1:$PORT/mcp
+
+Useful next checks:
+  $BIN doctor --json --root "$ROOT"
+  $BIN server list --json --root "$ROOT"
+  $BIN service status --json --root "$ROOT"
+  $BIN serve stop --json --root "$ROOT"
+DONE_EOF
