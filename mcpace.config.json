      "policy": {
        "scopeClass": "shared-global",
        "concurrencyPolicy": "single-writer",
        "stateBinding": "host-session",
        "credentialBinding": "none"
      },
      "required": true,
      "platforms": [
        "windows",
        "linux",
        "macos"
      ],
      "autoStart": true,
      "requiredCommands": [
        "npx"
      ],
      "healthUrl": "http://127.0.0.1:{abpPort}/api/v1/tabs",
      "installer": {
        "autoInstall": false,
        "installTarget": "none",
        "installMethod": "none",
        "installPackage": "",
        "binaryName": "",
        "verifyCommand": "",
        "postInstallMode": "none"
