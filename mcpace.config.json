{
  "name": "mcpace",
  "version": "0.3.0",
  "ports": {
    "abp": 39022,
    "hub": 12223
  },
  "hub": {
    "containerName": "mcpace",
    "image": "samanhappy/mcphub:0.12.12",
    "env": {
      "REQUEST_TIMEOUT": "180000"
    }
  },
  "abp": {
    "package": "agent-browser-protocol",
    "packageArgs": []
  },
  "packages": {
    "mcpRemote": "mcp-remote@0.1.18"
  },
  "profiles": {
    "runtime": {
      "default": "safe",
      "profiles": {
        "safe": {
          "description": "Required path plus source-default safe optional integrations.",
          "serverOverrides": {}
        },
        "extended": {
          "description": "Keeps the stable default path today and is reserved for validated local productivity integrations.",
          "serverOverrides": {}
        },
        "full": {
          "description": "Turns on all optional integrations and lets runtime gating decide what actually runs.",
          "serverOverrides": {
            "git": {
              "enabled": true
            },
            "github": {
              "enabled": true
            },
            "sentry": {
              "enabled": true
            },
            "windows-mcp": {
              "enabled": true
            },
            "screenpipe": {
              "enabled": true
            },
            "firecrawl": {
              "enabled": true
            }
          }
        },
        "labs": {
          "description": "Isolated candidate MCP profile for batch evaluation in dev sandboxes.",
          "serverOverrides": {
            "time": {
              "enabled": true
            },
            "pdf": {
              "enabled": true
            },
            "sqlite": {
              "enabled": true
            },
            "postgres": {
              "enabled": true
            },
            "brave-search": {
              "enabled": true
            },
            "everything": {
              "enabled": true
            }
          }
        }
      }
    }
  },
  "projects": {
    "discovery": {
      "roots": []
    }
  },
  "workspaces": {
    "primary": {
      "name": "primary",
      "hostPath": ".",
      "access": "rw"
    },
    "extras": []
  },
  "servers": {
