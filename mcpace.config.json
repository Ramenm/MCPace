{
  "name": "mcpace",
  "version": "0.3.6",
  "ports": {
    "abp": 15678,
    "hub": 12223
  },
  "hub": {
    "containerName": "mcpace",
    "image": "samanhappy/mcphub:0.12.12",
    "env": {
      "REQUEST_TIMEOUT": "180000"
    }
  },
  "abp": {
    "package": "agent-browser-protocol@0.1.10",
    "packageArgs": [
      "--mcp"
    ]
  },
  "packages": {
    "mcpRemote": "mcp-remote@0.1.18"
  },
  "profiles": {
    "runtime": {
      "default": "safe",
      "profiles": {
        "safe": {
          "description": "Required path plus source-default safe optional integrations.",
          "serverOverrides": {}
        },
        "extended": {
          "description": "Keeps the stable default path today and is reserved for validated local productivity integrations.",
          "serverOverrides": {}
        },
        "desktop": {
          "description": "Explicit workstation profile for local desktop-control MCP integrations guarded by host locks.",
          "serverOverrides": {
            "windows-mcp": {
              "enabled": true
            }
          }
        },
        "full": {
          "description": "Turns on all optional integrations and lets runtime gating decide what actually runs.",
          "serverOverrides": {
            "git": {
              "enabled": true
            },
            "github": {
              "enabled": true
            },
            "sentry": {
              "enabled": true
            },
            "windows-mcp": {
              "enabled": true
            },
            "screenpipe": {
              "enabled": true
            },
            "firecrawl": {
              "enabled": true
            },
            "notion": {
              "enabled": true
            },
            "playwright": {
              "enabled": true
            }
          }
        },
        "labs": {
          "description": "Isolated candidate MCP profile for batch evaluation in dev sandboxes.",
          "serverOverrides": {
            "time": {
              "enabled": true
            },
            "pdf": {
              "enabled": true
            },
            "sqlite": {
              "enabled": true
            },
            "postgres": {
              "enabled": true
            },
            "brave-search": {
              "enabled": true
            },
            "everything": {
              "enabled": true
            },
            "notion": {
              "enabled": true
            },
            "playwright": {
              "enabled": true
            },
            "git": {
              "enabled": true
            }
          }
        }
      }
    }
  },
  "projects": {
    "discovery": {
      "roots": []
    }
  },
  "workspaces": {
    "primary": {
      "name": "primary",
      "hostPath": ".",
      "access": "rw"
    },
    "extras": []
  },
  "servers": {
    "browser": {
      "kind": "host-bridge",
      "transportPreference": "stdio-http-bridge",
      "supportedTransports": [
        "stdio-http-bridge",
        "http"
      ],
      "policy": {
        "scopeClass": "shared-global",
        "concurrencyPolicy": "single-writer",
        "stateBinding": "host-session",
        "credentialBinding": "none",
        "parallelismLimit": 1,
        "conflictDomain": "browser-host",
        "projectRootMode": "optional",
        "worktreeBinding": "workspace-roots",
        "browserProfileMode": "project-session",
        "hostLock": "browser-profile",
        "startupStrategy": "lazy-per-profile",
        "routingGroup": "browser"
      },
      "required": true,
      "platforms": [
        "windows",
        "linux",
        "macos"
      ],
      "autoStart": true,
      "requiredCommands": [
        "npx"
      ],
      "healthUrl": "http://127.0.0.1:15678/api/v1/tabs",
      "installer": {
        "autoInstall": false,
        "installTarget": "none",
        "installMethod": "none",
        "installPackage": "",
        "binaryName": "",
        "verifyCommand": "",
        "postInstallMode": "none"
      },
      "toolPolicies": [
        {
          "tools": [
            "browser_action",
            "browser_scroll",
            "browser_navigate",
            "browser_tabs",
            "browser_javascript",
            "browser_dialog",
            "browser_downloads",
            "browser_files",
            "browser_select_picker",
            "cdp_mode",
            "browser_slider",
            "browser_clear_text",
            "respond_to_permission"
          ],
          "riskClass": "browser-control",
          "allowArgument": "allowBrowserControl",
          "description": "Agent Browser Protocol control tools can click, type, navigate, execute JavaScript, drive dialogs/downloads/files, or alter the visible host browser; require explicit opt-in while text/status/network/console reads remain available."
        }
      ]
    },
    "filesystem": {
      "kind": "container-stdio",
      "policy": {
        "scopeClass": "shared-global",
        "concurrencyPolicy": "single-writer",
        "stateBinding": "workspace-roots",
        "credentialBinding": "none",
        "parallelismLimit": 1,
        "conflictDomain": "filesystem-roots",
        "projectRootMode": "optional",
        "worktreeBinding": "workspace-roots",
        "browserProfileMode": "none",
        "hostLock": "none",
        "startupStrategy": "lazy-per-workspace",
        "routingGroup": "workspace"
