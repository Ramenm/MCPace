      "toolPolicies": [
        {
          "tools": [
            "write_file",
            "edit_file",
            "create_directory",
            "move_file",
            "delete_*",
            "remove_*"
          ],
          "riskClass": "filesystem-mutation",
          "allowArgument": "allowFilesystemMutation",
          "description": "Filesystem write/move/delete-style tools mutate workspace roots; require explicit mutation opt-in when the upstream does not expose trusted ToolAnnotations."
        }
      ],
      "workspaceBinding": {
        "defaultCwd": "none",
        "pathArgs": "allRoots",
        "isolateHome": false
      }
    },
