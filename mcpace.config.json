{
  "name": "mcpace",
  "version": "0.4.1",
  "ports": {
    "hub": 12223
  },
  "hub": {
    "containerName": "mcpace",
    "image": "samanhappy/mcphub:0.12.12",
    "env": {
      "REQUEST_TIMEOUT": "180000"
    }
  },
  "packages": {
    "mcpRemote": "mcp-remote@0.1.18"
  },
  "profiles": {
    "runtime": {
      "default": "manual",
      "profiles": {
        "manual": {
          "description": "No upstream MCP servers are enabled by default. Add any MCP server to mcp_settings.json; add mcpace.config.json policy only when needed.",
          "serverOverrides": {}
        },
        "labs": {
          "description": "Empty sandbox profile; use it for local experiments by adding explicit serverOverrides.",
          "serverOverrides": {}
        }
      }
    }
  },
  "projects": {
    "discovery": {
      "roots": []
    }
  },
  "workspaces": {
    "primary": {
      "name": "primary",
      "hostPath": ".",
      "access": "rw"
    },
    "extras": []
  },
  "servers": {},
  "client": {
    "keyName": "MCPace"
  },
  "health": {
    "probeTimeoutSec": 2,
    "startupTimeoutSec": 60,
    "offlineThreshold": 2
  },
  "platform": {
    "dockerHostAlias": "host.docker.internal",
    "windowsOnlyServers": []
  },
  "compatibility": {
    "sessionGate": {
      "enabled": true,
      "streamProbeMs": 0,
      "idleDelayMs": 1500,
      "logTailLines": 400
    }
  },
  "clientCatalog": {
    "paths": [],
    "targets": [],
    "description": "Optional external client target catalog. Built-ins remain a fallback; entries here or MCPACE_CLIENT_CATALOG can add/override clients without recompiling."
  }
}
