{
  "name": "@mcpace/cli",
  "version": "0.7.7",
  "description": "Thin npm launcher for the MCPace native Rust binary.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "mcpace": "bin/mcpace.js"
  },
  "files": [
    "bin",
    "lib",
    "release-targets.json",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./lib/resolve-binary.js",
    "./resolve-binary": "./lib/resolve-binary.js",
    "./platform": "./lib/platform.js",
    "./runtime": "./lib/runtime.js",
    "./targets": "./lib/targets.js",
    "./terminal-diagnostics": "./lib/terminal-diagnostics.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcpace",
    "mcp",
    "cli",
    "rust",
    "launcher"
  ],
  "optionalDependencies": {
    "@mcpace/cli-darwin-arm64": "0.7.7",
    "@mcpace/cli-darwin-x64": "0.7.7",
    "@mcpace/cli-linux-arm64-gnu": "0.7.7",
    "@mcpace/cli-linux-x64-gnu": "0.7.7",
    "@mcpace/cli-win32-arm64-msvc": "0.7.7",
    "@mcpace/cli-win32-x64-msvc": "0.7.7"
  },
  "mcpace": {
    "targetManifest": "release-targets.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ramenm/MCPace.git"
  },
  "bugs": {
    "url": "https://github.com/Ramenm/MCPace/issues"
  },
  "homepage": "https://github.com/Ramenm/MCPace#readme"
}
