{
  "version": "0.1.0",
  "runtime": {
    "mode": "local-hub",
    "stateDir": "data/runtime",
    "logDir": "logs",
    "ingress": {
      "stdioLaunchers": { "enabled": true },
      "streamableHttp": {
        "enabled": true,
        "bind": "127.0.0.1:12223",
        "authMode": "local-bearer"
      }
    }
  },
  "clients": {
    "default": "cursor",
    "supported": ["cursor", "vscode", "generic-stdio"]
  },
  "profiles": {
    "default": "manual",
    "definitions": {
      "manual": {
        "description": "No upstream MCP servers are enabled by default.",
        "serverIds": []
      }
    }
  },
  "servers": [],
  "projects": {
    "discoveryRoots": [],
    "stickySessions": true
  },
  "compatibility": {
    "legacyManagerBridge": false,
    "legacyScriptAliases": false
  }
}
