{
  "version": "0.1.0",
  "runtime": {
    "mode": "hybrid-hub",
    "stateDir": "data/runtime",
    "logDir": "logs",
    "ingress": {
      "stdioLaunchers": { "enabled": true },
      "streamableHttp": {
        "enabled": true,
        "bind": "127.0.0.1:12223",
        "authMode": "local-bearer"
      }
    }
  },
  "clients": {
    "default": "generic-stdio",
    "supported": ["cursor", "vscode", "claude-desktop", "windsurf", "generic-stdio", "generic-http"]
  },
  "profiles": {
    "default": "manual",
    "definitions": {
      "manual": {
        "description": "No upstream MCP servers are enabled by default.",
        "serverIds": []
      },
      "extended": {
        "description": "Opt-in profile. Add user-supplied upstream MCP server IDs before using it.",
        "serverIds": []
      }
    }
  },
  "servers": [],
  "projects": {
    "discoveryRoots": [],
    "stickySessions": true
  },
  "compatibility": {
    "legacyManagerBridge": false,
    "legacyScriptAliases": false
  }
}
