{
  "version": "0.6.5",
  "node": {
    "enginesRange": ">=22.0.0",
    "minimumNpm": "10.0.0",
    "packageManagerMajor": 11,
    "defaultMajor": 24,
    "supportedLtsMajors": [
      22,
      24
    ],
    "devEnginesRuntimeRange": "^22.0.0 || ^24.0.0",
    "devEnginesNpmRange": "^10.0.0 || ^11.0.0"
  },
  "packageManager": "npm@11.13.0",
  "rust": {
    "toolchain": "1.95.0",
    "profile": "minimal",
    "components": [
      "clippy",
      "rustfmt"
    ],
    "edition": "2021"
  },
  "githubActions": {
    "checkout": "v6",
    "setupNode": "v6",
    "uploadArtifact": "v7"
  },
  "ci": {
    "nodeSourceValidationMatrix": [
      {
        "os": "ubuntu-latest",
        "node": "22"
      },
      {
        "os": "ubuntu-latest",
        "node": "24"
      }
    ],
    "rustHosts": [
      "ubuntu-latest",
      "windows-latest",
      "macos-latest"
    ]
  },
  "architecture": {
    "thinModuleRoots": [
      "client",
      "hub",
      "lab",
      "server",
      "verify"
    ]
  }
}
