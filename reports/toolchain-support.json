{
  "asOf": "2026-04-19",
  "node": {
    "defaultMajor": 24,
    "supportedLtsMajors": [
      22,
      24
    ],
    "enginesRange": ">=22.0.0",
    "devEnginesRuntimeRange": "^22.0.0 || ^24.0.0",
    "minimumNpm": "10.0.0",
    "devEnginesNpmRange": "^10.0.0 || ^11.0.0"
  },
  "packageManager": "npm@11.12.1",
  "rust": {
    "toolchain": "1.95.0",
    "edition": "2021",
    "profile": "minimal",
    "components": [
      "clippy",
      "rustfmt"
    ]
  },
  "githubActions": {
    "checkout": "v6",
    "setupNode": "v6",
    "rustToolchain": "dtolnay/rust-toolchain@stable"
  },
  "ci": {
    "nodeSourceValidationMatrix": [
      {
        "os": "ubuntu-latest",
        "node": "22"
      },
      {
        "os": "ubuntu-latest",
        "node": "24"
      },
      {
        "os": "windows-latest",
        "node": "24"
      },
      {
        "os": "macos-latest",
        "node": "24"
      }
    ],
    "packageDryRun": {
      "os": "ubuntu-latest",
      "nodeVersionFile": ".nvmrc"
    },
    "rustHosts": [
      "ubuntu-latest",
      "windows-latest",
      "macos-latest"
    ]
  },
  "launcher": {
    "linuxLibcPolicy": "detect glibc explicitly, detect musl explicitly, and fail safe on unknown libc instead of assuming gnu"
  },
  "architecture": {
    "thinModuleRoots": [
      "client",
      "hub",
      "lab",
      "server",
      "verify"
    ],
    "goal": "keep large command families split into args, loader, model, render, and analysis submodules instead of single large files"
  },
  "release": {
    "archiveBuilderScript": "scripts/archive-release.mjs",
    "archiveRootPattern": "<project-name>-v<version>-<ddmmyy-hhmmss>"
  }
}
