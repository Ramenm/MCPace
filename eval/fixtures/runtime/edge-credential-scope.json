{
  "id": "edge-credential-scope",
  "suite": "partitioning",
  "category": "edge",
  "proofLayer": "planner",
  "heldOut": false,
  "title": "Credential-scoped partitioning",
  "objective": "Prefer a credential profile id over coarse binding classes when the client or shim provides one.",
  "traffic": {
    "clientArchetype": "generic-stdio",
    "serverPolicies": ["credential-scoped", "single-writer"],
    "signals": ["clientInfo", "_meta", "credentialProfileId"]
  },
  "checks": ["must-use-credential-profile-when-present", "must-fallback-coarsely-when-missing"],
  "requires": ["planner-context-resolution", "planner-credential-partition", "planner-conservative-server-policy"]
}
