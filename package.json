    "verify:runtime-trace": "node scripts/runtime-trace-harness.mjs --json --write reports/runtime-trace-latest.json --markdown reports/runtime-trace-latest.md",
    "verify:github-readiness": "node scripts/verify-github-readiness.mjs --json --write reports/github-readiness-latest.json --markdown reports/github-readiness-latest.md",
    "verify:defect-gates": "node scripts/defect-gates.mjs --json --write reports/defect-gates-latest.json --markdown reports/defect-gates-latest.md",
    "verify:github-health": "node scripts/github-health-audit.mjs --json --write reports/github-health-latest.json --markdown reports/github-health-latest.md",
    "verify:bug-sweep": "node scripts/bug-sweep.mjs --json --write reports/bug-sweep-latest.json --markdown reports/bug-sweep-latest.md",
    "verify:tooling": "node scripts/tooling-readiness.mjs --json --write reports/tooling-readiness-latest.json --markdown reports/tooling-readiness-latest.md",
    "verify:tooling:strict": "node scripts/tooling-readiness.mjs --json --write reports/tooling-readiness-latest.json --markdown reports/tooling-readiness-latest.md --strict",
    "verify:local-prepublish:plan": "node scripts/local-prepublish-gate.mjs --json --plan-only",
    "verify:local-prepublish:quick": "node scripts/local-prepublish-gate.mjs --quick --json --write reports/local-prepublish-latest.json --markdown reports/local-prepublish-latest.md",
    "verify:local-prepublish": "node scripts/local-prepublish-gate.mjs --json --write reports/local-prepublish-latest.json --markdown reports/local-prepublish-latest.md --strict",
    "prove:offline": "npm run verify:local-prepublish",
    "hooks:install": "node scripts/install-local-hooks.mjs",
    "hooks:install:dry-run": "node scripts/install-local-hooks.mjs --dry-run --json",
    "verify:toolbox": "node scripts/toolbox-doctor.mjs --json --write reports/toolbox-doctor-latest.json --markdown reports/toolbox-doctor-latest.md",
    "verify:local:quick": "npm run verify:toolbox && npm run verify:local:smoke && npm run verify:publish-decision",
    "verify:local:smoke": "bash scripts/local-quality-smoke.sh",
    "verify:local:source": "node scripts/local-quality-suite.mjs --profile source --json --write reports/local-quality-source-latest.json --markdown reports/local-quality-source-latest.md",
    "verify:local:full": "node scripts/local-quality-suite.mjs --profile full --json --write reports/local-quality-full-latest.json --markdown reports/local-quality-full-latest.md",
    "verify:local:host": "npm run verify:local:full",
    "quality:local:full": "npm run verify:local:full",
    "verify:local:release": "node scripts/local-quality-suite.mjs --profile release --json --write reports/local-quality-release-latest.json --markdown reports/local-quality-release-latest.md",
    "verify:local:suite:smoke": "node scripts/local-quality-suite.mjs --profile smoke --json --write reports/local-quality-smoke-suite-latest.json --markdown reports/local-quality-smoke-suite-latest.md",
    "verify:local:suite:source": "node scripts/local-quality-suite.mjs --profile source --json --write reports/local-quality-source-latest.json --markdown reports/local-quality-source-latest.md",
    "verify:local:suite:full": "node scripts/local-quality-suite.mjs --profile full --json --write reports/local-quality-full-latest.json --markdown reports/local-quality-full-latest.md",
    "verify:local:suite:release": "node scripts/local-quality-suite.mjs --profile release --json --write reports/local-quality-release-latest.json --markdown reports/local-quality-release-latest.md",
