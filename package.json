    "prove:local-first": "npm run verify:local:quick && npm run verify:local:source && npm run verify:free-tier && npm run verify:publish-decision",
    "test:repo:json": "npm run test:repo",
    "test:repo:node": "npm run test:repo",
    "test:repo:smoke": "node scripts/run-node-test-files.mjs --dir tests/node --ext .test.js --json --progress --timeout-ms 60000 --heartbeat-ms 10000 --only local-quality-contract --only publish-decision-contract --only source-quality-contract --only security-contract --only github-readiness-contract --only bug-sweep-contract --only defect-gates-contract --write reports/node-tests-smoke-latest.json",
    "test:npm:node": "npm run test:npm",
    "test:source": "npm run lint:npm && npm run audit:source && npm run verify:defect-gates && npm run verify:bug-sweep && npm run test:repo && npm run test:npm",
    "audit:ready-footprint": "node scripts/ready-footprint-audit.mjs --json",
    "test:repo:serial": "node scripts/run-node-test-files.mjs --dir tests/node --ext .test.js --json --progress --batch-size 1 --timeout-ms 120000 --heartbeat-ms 10000 --write reports/node-tests-latest.json",
    "test:npm:serial": "node scripts/run-node-test-files.mjs --dir packages/npm/cli/test --ext .test.mjs --json --progress --batch-size 1 --timeout-ms 120000 --heartbeat-ms 10000 --write reports/npm-cli-tests-latest.json",
    "verify:linux:auto": "node scripts/linux-auto-check.mjs --profile standard --json --write reports/linux-auto-check-latest.json --markdown reports/linux-auto-check-latest.md",
    "verify:linux:auto:host": "node scripts/linux-auto-check.mjs --profile host --json --write reports/linux-auto-check-latest.json --markdown reports/linux-auto-check-latest.md --no-docker",
    "verify:linux:auto:full": "node scripts/linux-auto-check.mjs --profile full --json --write reports/linux-auto-check-full-latest.json --markdown reports/linux-auto-check-full-latest.md",
    "verify:linux:auto:release": "node scripts/linux-auto-check.mjs --profile release --json --write reports/linux-auto-check-release-latest.json --markdown reports/linux-auto-check-release-latest.md",
    "setup:linux:auto": "bash scripts/linux-auto-setup.sh",
