{
  "name": "mcpace-workspace",
  "version": "0.6.9",
  "private": true,
  "workspaces": [
    "packages/npm/cli"
  ],
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "lint:npm": "node scripts/check-node-syntax.mjs --json",
    "test:npm": "node --test packages/npm/cli/test/*.test.mjs tests/node/*.test.mjs",
    "check": "npm run lint:npm && npm run test:npm",
    "ci:local:quick": "npm run check",
    "ci": "npm run check",
    "build": "cargo build --release",
    "test:rust": "cargo test",
    "test": "npm run test:npm",
    "pack:npm:dry-run": "npm pack --workspace @mcpace/cli --json --dry-run",
    "load:local": "node scripts/load-test-local.mjs",
    "test:logic": "node scripts/logic-test-local.mjs"
  },
  "packageManager": "npm@10.9.2",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^22.0.0 || ^24.0.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": "^10.0.0 || ^11.0.0",
      "onFail": "error"
    }
  }
}
