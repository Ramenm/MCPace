    "verify:rust-quality:plan": "node scripts/verify-rust-quality.mjs --json --plan-only",
    "test:node:coverage": "node --test --test-force-exit --experimental-test-coverage tests/node/*.test.js packages/npm/cli/test/*.test.mjs",
    "inventory:source": "node scripts/inventory-source.mjs --json --write reports/code-inventory-latest.json --markdown reports/code-inventory-latest.md",
    "inventory:project": "node scripts/inventory-project.mjs --json --write-json reports/code-inventory-20260502.json --write-md reports/code-inventory-20260502.md",
    "boot:harness": "node scripts/boot-harness.mjs --json --write reports/boot-harness-latest.json --markdown reports/boot-harness-latest.md",
    "verify:boot": "node scripts/boot-harness.mjs --json --write reports/boot-harness-latest.json --markdown reports/boot-harness-latest.md",
    "verify:install-readiness": "node scripts/install-readiness-harness.mjs --json --write reports/install-readiness-latest.json",
