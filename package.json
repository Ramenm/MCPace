{
  "name": "mcpace-workspace",
  "version": "0.5.9",
  "private": true,
  "workspaces": [
    "packages/npm/cli"
  ],
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "lint:npm": "node scripts/check-node-syntax.mjs --json",
    "test:repo": "node scripts/run-node-test-files.mjs --dir tests/node --ext .test.js",
    "test:npm": "node scripts/run-node-test-files.mjs --dir packages/npm/cli/test --ext .test.mjs",
    "test:rust": "node scripts/run-rust-tests.mjs",
    "test:rust:launcher:host": "cargo test --test hub_runtime hub_up_releases_captured_stdio_for_background_launcher -- --exact",
    "test:rust:launcher:ubuntu-docker": "node scripts/verify-ubuntu-docker-fast.mjs --json",
    "test:e2e:ubuntu-docker": "node scripts/verify-ubuntu-docker-e2e.mjs --json",
    "test:full:ubuntu-docker": "node scripts/verify-ubuntu-docker-full.mjs --json",
    "build:rust:release": "cargo build --release",
    "pack:npm:dry-run": "npm pack --workspace @mcpace/cli --json --dry-run",
    "prove:local": "npm run prove:source && npm run prove:rust-host",
    "test": "npm run lint:npm && npm run audit:source && npm run test:repo && npm run test:npm",
    "prove:source": "npm test && npm run verify:npm-pack && npm run verify:install-readiness",
    "prove:report": "node scripts/proof-report.mjs --json --write",
    "prove:rust-host": "npm run verify:rust-quality",
    "archive:release": "node scripts/archive-release.mjs --json",
    "benchmark:runtime": "node scripts/benchmark-runtime.mjs",
    "stage:vendored-binary": "node scripts/stage-vendored-binary.mjs --json",
    "verify:vendored-binary": "node scripts/verify-vendored-binary.mjs --json",
    "verify:npm-pack": "node scripts/verify-npm-pack.mjs --json",
    "generate:checksums": "node scripts/generate-checksums.mjs --json",
    "build:release-artifacts": "node scripts/build-release-artifacts.mjs --json",
    "verify:release-targets": "node scripts/verify-release-targets.mjs --json",
    "sync:platform-packages": "node scripts/sync-platform-packages.mjs --json",
    "verify:platform-packages": "node scripts/verify-platform-packages.mjs --json",
    "verify:platform-packages:packed": "node scripts/verify-platform-packages.mjs --json --pack-dry-run",
    "stage:platform-package-binary": "node scripts/stage-platform-package-binary.mjs --json",
    "publish:npm:artifacts:dry-run": "node scripts/publish-npm-artifacts.mjs --json --dry-run",
    "publish:npm:artifacts": "node scripts/publish-npm-artifacts.mjs --json",
    "verify:publish-readiness": "node scripts/verify-publish-readiness.mjs --json",
    "test:rust:ci": "node scripts/run-rust-tests.mjs --json --profile non-lifecycle",
    "test:rust:full": "node scripts/run-rust-tests.mjs --json --profile full",
    "test:rust:lifecycle": "node scripts/run-rust-tests.mjs --json --profile lifecycle",
    "generate:release-matrix": "node scripts/github-release-matrix.mjs --json",
    "verify:release-checksums": "node scripts/verify-release-checksums.mjs --json",
    "test:linux-npm-install:docker": "node scripts/verify-linux-npm-install-docker.mjs --json",
    "verify:macos-proof-lanes": "node scripts/verify-macos-proof-lanes.mjs --json",
    "audit:source": "node scripts/audit-source.mjs --fail-on-critical",
    "verify:rust-quality": "node scripts/verify-rust-quality.mjs --json --write reports/rust-quality-latest.json",
    "verify:rust-quality:plan": "node scripts/verify-rust-quality.mjs --json --plan-only",
    "test:node:coverage": "node --test --test-force-exit --experimental-test-coverage tests/node/*.test.js packages/npm/cli/test/*.test.mjs",
    "inventory:source": "node scripts/inventory-source.mjs --json --write reports/code-inventory-latest.json --markdown reports/code-inventory-latest.md",
    "inventory:project": "node scripts/inventory-project.mjs --json --write-json reports/code-inventory-20260502.json --write-md reports/code-inventory-20260502.md",
    "boot:harness": "node scripts/boot-harness.mjs --json --write reports/boot-harness-latest.json --markdown reports/boot-harness-latest.md",
    "verify:boot": "node scripts/boot-harness.mjs --json --write reports/boot-harness-latest.json --markdown reports/boot-harness-latest.md",
    "verify:install-readiness": "node scripts/install-readiness-harness.mjs --json --write reports/install-readiness-latest.json",
    "lint:node": "node scripts/check-node-syntax.mjs --json",
    "verify:product-practice": "node scripts/product-practice-harness.mjs --json --write reports/product-practice-latest.json --markdown reports/product-practice-latest.md",
    "verify:runtime-trace": "node scripts/runtime-trace-harness.mjs --json --write reports/runtime-trace-latest.json --markdown reports/runtime-trace-latest.md"
  },
  "packageManager": "npm@11.12.1",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^22.0.0 || ^24.0.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": "^10.0.0 || ^11.0.0",
      "onFail": "error"
    }
  }
}
