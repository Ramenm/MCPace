    "smoke:mcp:http": "node scripts/mcp-http-smoke.mjs --json --write reports/mcp-http-smoke-latest.json",
    "verify:ideal:source": "npm run lint:npm && npm run test:repo:smoke && npm run test:npm && npm run verify:secrets -- --json && npm run doctor:full",
    "verify:lifecycle": "npm run verify:system-lifecycle && node --test tests/node/runtime-lifecycle-contract.test.js tests/node/system-lifecycle-contract.test.js",
