{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/mcpace-config.schema.json",
  "title": "MCPace Project Configuration",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "name",
    "version",
    "ports",
    "serve",
    "mcpSettings",
    "servers"
  ],
  "properties": {
    "name": {
      "type": "string",
      "const": "mcpace"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "ports": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "hub",
        "serve"
      ],
      "properties": {
        "hub": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "serve": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "serve": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "host",
        "port",
        "mcpPath",
        "publicUrl"
      ],
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "mcpPath": {
          "type": "string",
          "pattern": "^/[^\\s?#]*$"
        },
        "publicUrl": {
          "type": "string"
        }
      }
    },
    "mcpSettings": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "includePaths",
        "includeDirs"
      ],
      "properties": {
        "includePaths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "includeDirs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "servers": {
      "type": "object",
      "additionalProperties": true
    },
    "clientCatalog": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "targets": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "mcpPresets": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "includePaths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
